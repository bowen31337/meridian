{
  "name": "@meridian/sdk-ts",
  "version": "0.1.0",
  "description": "Meridian TypeScript SDK — generated API client (owned by codegen pipeline)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
