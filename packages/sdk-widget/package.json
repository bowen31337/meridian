{
  "name": "@meridian/sdk-widget",
  "version": "0.1.0",
  "description": "Meridian Live Canvas Widget SDK — React component contract, manifest schema, canvas_op render pipeline, and layout helpers",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
