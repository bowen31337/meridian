[importlinter]
root_packages =
    api_capabilities
    core_errors
    meridiand
    meridian_builtin_tools
    meridian_cli
    meridian_kb_indexer
    meridian_plugin_loader
    meridian_sdk_provider
    meridian_sdk_tool
    sdk_capabilities
    sdk_channel
    sdk_environment
    sdk_sandbox
    storage_blob
    storage_event_log
    storage_reposit
    storage_repository
    system_ulid

# --- Contract 1: Cross-package layering ---
# Apps (Layer 3) may import from composed or foundation packages.
# Composed packages (Layer 2) may import from foundation only.
# Foundation packages (Layer 1) may not import from any other workspace package.
[importlinter:contract:layering]
name = Cross-package layering
type = layers
layers =
    meridiand | meridian_cli
    api_capabilities | meridian_builtin_tools | meridian_plugin_loader | storage_reposit
    core_errors | system_ulid | sdk_capabilities | sdk_channel | sdk_environment | meridian_sdk_provider | sdk_sandbox | meridian_sdk_tool | storage_blob | storage_event_log | storage_repository | meridian_kb_indexer

# --- Contract 2: Foundation packages are independent ---
# No foundation package may import from any other foundation package.
[importlinter:contract:foundation-independence]
name = Foundation packages are independent
type = independence
modules =
    core_errors
    system_ulid
    sdk_capabilities
    sdk_channel
    sdk_environment
    meridian_sdk_provider
    sdk_sandbox
    meridian_sdk_tool
    storage_blob
    storage_event_log
    storage_repository
    meridian_kb_indexer

# --- Contract 3: Composed packages are independent from each other ---
# Composed packages may only depend downward into foundation; they must not
# cross-import from sibling composed packages.
[importlinter:contract:composed-independence]
name = Composed packages are independent from each other
type = independence
modules =
    api_capabilities
    meridian_builtin_tools
    meridian_plugin_loader
    storage_reposit

# --- Contract 4: §13.5 ModelProvider isolation ---
# No provider adapter package may import the Session Service, Vault, or
# Sandbox directly.  Provider adapters receive a ModelCallOpts, yield
# ModelEvents, and must not reach into system internals.
[importlinter:contract:provider-isolation]
name = §13.5 ModelProvider isolation — no Session Service, Vault, or Sandbox imports
type = forbidden
source_modules =
    meridian_sdk_provider
forbidden_modules =
    meridiand._sessions
    meridiand._vaults
    meridiand._credential_proxy
    sdk_sandbox
    storage_event_log
